/* app.wxss - 全局样式 */

/* 主题色变量 */
page {
  --primary-color: #4A90D9;
  --primary-light: #E8F1FB;
  --success-color: #4caf50;
  --warning-color: #ff9800;
  --danger-color: #f44336;
  --text-color: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --border-color: #e5e5e5;
  --bg-color: #f5f5f5;
  --white: #ffffff;

  font-size: 28rpx;
  color: var(--text-color);
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--white);
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--primary-color);
  color: var(--white);
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-primary::after {
  border: none;
}

.btn-default::after {
  border: none;
}

.btn-danger::after {
  border: none;
}

.btn-default {
  background-color: var(--white);
  color: var(--text-color);
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-danger {
  background-color: var(--danger-color);
  color: var(--white);
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

/* 浮动添加按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: var(--white);
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-textarea {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  min-height: 200rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

/* 选择器 */
.picker {
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  background-color: var(--white);
  font-size: 30rpx;
}

.picker-placeholder {
  color: var(--text-placeholder);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.tag-success {
  background-color: #e8f5e9;
  color: var(--success-color);
}

.tag-warning {
  background-color: #fff3e0;
  color: var(--warning-color);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-placeholder);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--primary-color);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

/* 评分星星 */
.rating {
  display: flex;
  align-items: center;
}

.star {
  font-size: 40rpx;
  color: #ddd;
  margin-right: 8rpx;
}

.star.active {
  color: #ffc107;
}

/* 状态徽章 */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-pending {
  background-color: #fff3e0;
  color: var(--warning-color);
}

.status-explained {
  background-color: #e3f2fd;
  color: #2196f3;
}

.status-mastered {
  background-color: #e8f5e9;
  color: var(--success-color);
}

.status-completed {
  background-color: #e8f5e9;
  color: var(--success-color);
}