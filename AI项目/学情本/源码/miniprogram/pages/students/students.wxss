/* pages/students/students.wxss */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.search-box {
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  padding: 22rpx 28rpx;
  background-color: var(--white);
  border-radius: 12rpx;
  font-size: 30rpx;
}

.student-list {
  padding-bottom: 120rpx;
}

.empty-state {
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: var(--text-placeholder);
}