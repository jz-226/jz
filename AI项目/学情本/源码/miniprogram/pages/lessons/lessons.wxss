/* pages/lessons/lessons.wxss */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.filter-box {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.picker {
  padding: 16rpx 24rpx;
  background-color: var(--white);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
}

.filter-picker {
  flex: 1;
  justify-content: space-between;
}

.date-picker {
  justify-content: space-between;
}

.arrow {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.icon {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.lesson-list {
  padding-bottom: 120rpx;
}

.empty-state {
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: var(--text-placeholder);
}