/* pages/lesson-edit/lesson-edit.wxss */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.form {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.form-label.required::before {
  content: '*';
  color: var(--danger-color);
  margin-right: 8rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-textarea {
  min-height: 200rpx;
}

.picker {
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
}

.picker-placeholder {
  color: var(--text-placeholder);
}

.status-list {
  display: flex;
  gap: 12rpx;
}

.status-tag {
  padding: 16rpx 28rpx;
  border-radius: 10rpx;
  border: 1rpx solid var(--border-color);
  font-size: 28rpx;
  color: var(--text-secondary);
  background-color: var(--white);
}

.status-tag.selected {
  background-color: var(--primary-light);
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.objective-list,
.point-list,
.exercise-list {
  margin-top: 12rpx;
}

.objective-item,
.point-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.objective-input,
.point-input {
  flex: 1;
  padding: 20rpx 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.remove-btn {
  width: 40rpx;
  height: 40rpx;
  margin-left: 12rpx;
  color: var(--danger-color);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exercise-item {
  margin-bottom: 24rpx;
  padding: 20rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  position: relative;
}

.exercise-textarea {
  width: 100%;
  padding: 16rpx;
  font-size: 28rpx;
  min-height: 140rpx;
  line-height: 1.5;
}

.exercise-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
}

.add-btn {
  padding: 20rpx;
  text-align: center;
  color: var(--primary-color);
  font-size: 28rpx;
  border: 1rpx dashed var(--primary-color);
  border-radius: 10rpx;
  margin-top: 12rpx;
}

.submit-box {
  padding: 24rpx;
}

.btn-primary {
  width: 100%;
  margin-bottom: 12rpx;
}

.btn-default {
  width: 100%;
}