/* pages/student-edit/student-edit.wxss */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: #f5f7fa;
}

/* 表单卡片 */
.form-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 表单组 */
.form-group {
  margin-bottom: 40rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

/* 标签行 */
.form-label-box {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-star {
  font-size: 32rpx;
  color: #f44336;
  margin-right: 6rpx;
  font-weight: bold;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

/* 输入框外层包裹 - 聚焦光晕效果 */
.input-wrapper {
  position: relative;
}

/* 输入框 - 核心改进：大边框 + 背景色 + 聚焦态 */
.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background-color: #f8f9fc;
  border: 2rpx solid #dcdfe6;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #222;
  box-sizing: border-box;
  line-height: 96rpx;
  transition: border-color 0.2s, background-color 0.2s, box-shadow 0.2s;
}

.form-input:focus {
  border-color: #4A90D9;
  background-color: #fff;
  box-shadow: 0 0 0 8rpx rgba(74, 144, 217, 0.08);
}

.input-placeholder {
  color: #c0c4cc;
  font-size: 30rpx;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx 32rpx;
  background-color: #f8f9fc;
  border: 2rpx solid #dcdfe6;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #222;
  box-sizing: border-box;
  line-height: 1.7;
  transition: border-color 0.2s, background-color 0.2s, box-shadow 0.2s;
}

.form-textarea:focus {
  border-color: #4A90D9;
  background-color: #fff;
  box-shadow: 0 0 0 8rpx rgba(74, 144, 217, 0.08);
}

/* 字符计数 */
.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #c0c4cc;
  margin-top: 8rpx;
}

/* 选择器 */
.picker-box {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background-color: #f8f9fc;
  border: 2rpx solid #dcdfe6;
  border-radius: 16rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: border-color 0.2s;
}

.picker-value {
  color: #222;
}

.picker-placeholder {
  color: #c0c4cc;
}

.picker-arrow {
  font-size: 22rpx;
  color: #999;
}

/* 科目选择 */
.subject-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.subject-tag {
  padding: 18rpx 32rpx;
  border-radius: 12rpx;
  border: 2rpx solid #dcdfe6;
  font-size: 28rpx;
  color: #666;
  background-color: #f8f9fc;
  transition: all 0.2s;
}

.subject-tag:active {
  transform: scale(0.96);
}

.subject-tag.selected {
  background-color: #e8f1fb;
  border-color: #4A90D9;
  color: #4A90D9;
  font-weight: 600;
}

/* 提交按钮 */
.submit-box {
  padding: 40rpx 0 60rpx;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
  transition: transform 0.15s, box-shadow 0.15s;
}

.btn-save::after {
  border: none;
}

.btn-save:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.25);
}
