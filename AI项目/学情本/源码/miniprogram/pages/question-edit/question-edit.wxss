/* pages/question-edit/question-edit.wxss */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.form {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.form-label.required::before {
  content: '*';
  color: var(--danger-color);
  margin-right: 8rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-textarea {
  min-height: 200rpx;
}

.form-textarea.large {
  min-height: 260rpx;
}

.picker {
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 30rpx;
}

.picker-placeholder {
  color: var(--text-placeholder);
}

.status-list {
  display: flex;
  gap: 16rpx;
}

.status-tag {
  flex: 1;
  padding: 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--white);
}

.status-tag.selected {
  border-color: var(--primary-color);
  color: var(--primary-color);
  background-color: var(--primary-light);
}

.status-icon {
  margin-right: 8rpx;
}

.submit-box {
  padding: 24rpx;
}

.btn-primary {
  width: 100%;
  margin-bottom: 12rpx;
}

.btn-default {
  width: 100%;
}